---
import { SettingsDropdown } from './SettingsDropdown';
---

<header class="bg-brown-900 dark:bg-beige-100 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-2 sm:px-4">
    <div class="flex items-center justify-between h-16">
      <!-- Logo/Title -->
      <div class="flex items-center gap-2 sm:gap-4 flex-1 min-w-0">
        <a href="/" class="group focus-visible:outline-none flex-shrink-0" aria-label="Tangut Explorer home">
          <div class="font-tangut text-3xl sm:text-4xl text-beige-100 dark:text-brown-900 leading-none">
            𗼎
          </div>
        </a>
        <a href="/" class="group focus-visible:outline-none hidden sm:block min-w-0">
          <h1 class="font-ui text-xl sm:text-2xl md:text-3xl font-bold text-beige-100 dark:text-brown-900 tracking-tight truncate">
            TANGUT EXPLORER
          </h1>
          <p class="font-ui text-xs text-beige-300 dark:text-brown-700 uppercase tracking-widest truncate">
            A Resource for the Tangut Script
          </p>
        </a>
      </div>
      
      <div class="flex items-center gap-2 sm:gap-4 flex-shrink-0">
        <!-- Desktop Navigation -->
        <nav class="hidden sm:flex items-center gap-1" aria-label="Main navigation">
          <a 
            href="/" 
            class="font-ui text-sm font-semibold px-4 py-2 text-beige-100 dark:text-brown-900 hover:bg-brown-800 dark:hover:bg-beige-200 rounded transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-beige-100 dark:focus-visible:ring-brown-900"
          >
            Dictionary
          </a>
          <span class="text-beige-300 dark:text-brown-700" aria-hidden="true">|</span>
          <a 
            href="/flashcards" 
            class="font-ui text-sm font-semibold px-4 py-2 text-beige-100 dark:text-brown-900 hover:bg-brown-800 dark:hover:bg-beige-200 rounded transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-beige-100 dark:focus-visible:ring-brown-900"
          >
            Flashcards
          </a>
        </nav>

        <!-- Settings Dropdown (ATProto, Theme, Language) -->
        <SettingsDropdown client:load />

        <!-- Mobile Menu Button -->
        <button
          id="mobile-menu-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="mobile-menu"
          class="sm:hidden relative w-10 h-10 flex items-center justify-center text-beige-100 dark:text-brown-900 hover:bg-brown-800 dark:hover:bg-beige-200 rounded-full transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-beige-100 dark:focus-visible:ring-brown-900"
          aria-label="Toggle menu"
        >
          <svg class="w-6 h-6 p-[2px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path id="menu-line-1" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16" class="transition-all duration-300 origin-center" style="transform-origin: center;" />
            <path id="menu-line-2" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 12h16" class="transition-all duration-300 origin-center" />
            <path id="menu-line-3" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 18h16" class="transition-all duration-300 origin-center" style="transform-origin: center;" />
          </svg>
        </button>
      </div>
    </div>
    
    <!-- Mobile Menu (collapsible) -->
    <nav 
      id="mobile-menu" 
      class="sm:hidden grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-in-out invisible" 
      aria-label="Mobile navigation"
    >
      <div class="overflow-hidden">
        <div class="flex flex-col gap-2 pb-4">
          <a 
            href="/" 
            class="font-ui text-base font-semibold px-4 py-2 text-beige-100 dark:text-brown-900 hover:bg-brown-800 dark:hover:bg-beige-200 rounded transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-beige-100 dark:focus-visible:ring-brown-900"
          >
            Dictionary
          </a>
          <a 
            href="/flashcards" 
            class="font-ui text-base font-semibold px-4 py-2 text-beige-100 dark:text-brown-900 hover:bg-brown-800 dark:hover:bg-beige-200 rounded transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-beige-100 dark:focus-visible:ring-brown-900"
          >
            Flashcards
          </a>
        </div>
      </div>
    </nav>
  </div>
</header>

<script>
  document.addEventListener('astro:page-load', () => {
    // Mobile menu toggle
    const menuToggle = document.getElementById('mobile-menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const line1 = document.getElementById('menu-line-1');
    const line2 = document.getElementById('menu-line-2');
    const line3 = document.getElementById('menu-line-3');
    
    menuToggle?.addEventListener('click', () => {
      const isExpanded = menuToggle.getAttribute('aria-expanded') === 'true';
      const nextState = !isExpanded;
      
      menuToggle.setAttribute('aria-expanded', String(nextState));
      
      if (mobileMenu) {
        if (nextState) {
          mobileMenu.classList.remove('grid-rows-[0fr]', 'invisible');
          mobileMenu.classList.add('grid-rows-[1fr]');
        } else {
          mobileMenu.classList.remove('grid-rows-[1fr]');
          mobileMenu.classList.add('grid-rows-[0fr]');
          // Wait for transition to finish before hiding with invisible
          setTimeout(() => {
            if (menuToggle.getAttribute('aria-expanded') === 'false') {
              mobileMenu.classList.add('invisible');
            }
          }, 300);
        }
      }
      
      if (nextState) {
        // Morph to X
        line1?.setAttribute('d', 'M6 18L18 6');
        if (line2) line2.style.opacity = '0';
        line3?.setAttribute('d', 'M6 6l12 12');
      } else {
        // Revert to burger
        line1?.setAttribute('d', 'M4 6h16');
        if (line2) line2.style.opacity = '1';
        line3?.setAttribute('d', 'M4 18h16');
      }
    });
  });
</script>
