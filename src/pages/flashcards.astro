---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import FlashcardApp from '../components/FlashcardApp';
---

<Layout title="Flashcards - Tangut Explorer">
  <div class="min-h-screen">
    <Header />
    
    <main id="main-content" class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="mb-6">
        <p class="font-ui text-sm text-brown-600 dark:text-beige-400">
          Your progress is saved to localStorage.
        </p>
      </div>
      
      <FlashcardApp client:load />
    </main>
  </div>
</Layout>
