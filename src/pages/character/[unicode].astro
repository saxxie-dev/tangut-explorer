---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import RelatedCharacterSection from '../../components/RelatedCharacterSection.astro';
import { getUnicodeString, isValidTangutCharacter } from '../../utils/tangut';
import { getAllCharacterData, type CharacterData } from '../../utils/database.ts';

export async function getStaticPaths() {
  const allCharacters = await getAllCharacterData();
  return Array.from(allCharacters.values()).map((characterData: CharacterData) => ({
    params: { unicode: characterData.unicode_string },
    props: { characterData }
  }));
}

const { characterData } = Astro.props as { characterData: CharacterData };
const { unicode: unicodeParam } = Astro.params;

// Validate the character
if (!characterData || !isValidTangutCharacter(unicodeParam || '')) {
  return Astro.redirect('/404');
}

const pageTitle = `${characterData.unicode} (${characterData.unicode_string}) - Tangut Explorer`;

let tone = '';
if (characterData.rhyme_class) {
  if (characterData.rhyme_class.startsWith('1')) {
    tone = '¹';
  } else if (characterData.rhyme_class.startsWith('2')) {
    tone = '²';
  }
}

// Combine similar and same radical
const similarCharacters = [
  ...(characterData.similar_ids_radical || []),
  ...(characterData.similar_ids_rest || [])
];
---

<Layout title={pageTitle}>
  <div class="min-h-screen">
    <Header />
    
    <main id="main-content" class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Character Display -->
      <div class="text-center">
        <!-- Main Character, Reading, and Definition Grid -->
        <div class="mb-8 p-0 border-2 border-brown-900 dark:border-beige-100 bg-beige-100 dark:bg-brown-800 grid grid-cols-2 grid-rows-2">
          <!-- Character (2x1) -->
          <div class="col-span-1 row-span-2 flex items-center justify-center p-4 border-r-2 border-brown-900 dark:border-beige-100">
            <div class="font-tangut text-[150px] md:text-[200px] text-brown-900 dark:text-beige-100 leading-none">
              {characterData.unicode}
            </div>
          </div>

          <!-- Reading (1x1) -->
          <div class="col-span-1 row-span-1 flex flex-col items-center justify-center p-4 border-b-2 border-brown-900 dark:border-beige-100">
            {characterData.gong_huangcheng_reading ? (
              <div class="font-reading text-3xl md:text-4xl text-brown-700 dark:text-beige-300">
                {characterData.gong_huangcheng_reading}{tone}
              </div>
            ) : (
              <div class="font-ui text-base text-brown-600 dark:text-beige-400 italic">
                No reading data
              </div>
            )}
            {characterData.pronunciation_warning && (
              <div class="mt-2 text-center">
                <p class="font-ui text-xs text-red-700 dark:text-red-300 font-semibold">
                  Pronunciation may be incomplete
                </p>
              </div>
            )}
          </div>

          <!-- Definition (1x1) -->
          <div class="col-span-1 row-span-2 flex flex-col items-center justify-center p-4">
            {characterData.english_definition ? (
              <div class="font-ui text-lg md:text-xl text-brown-900 dark:text-beige-100 leading-relaxed max-w-xs">
                {characterData.english_definition}
              </div>
            ) : (
              <div class="font-ui text-base text-brown-600 dark:text-beige-400 italic">
                No definition data
              </div>
            )}
            {characterData.variant_warning && (
              <div class="mt-2 text-center">
                <p class="font-ui text-xs text-amber-700 dark:text-amber-300 font-medium">
                  Definition may be misaligned
                </p>
              </div>
            ) }
          </div>

          <!-- IDS -->
          <div class="col-span-1 flex items-center justify-center p-2 border-r-2 border-t-2 border-brown-900 dark:border-beige-100 bg-beige-100 dark:bg-brown-800">
              <p class="font-tangut text-xl md:text-2xl text-brown-900 dark:text-beige-100 leading-none">
                {characterData.ids_sequence}
              </p>
          </div>
        </div>
        
        <!-- Character Info -->
        <div class="bg-brown-900 dark:bg-beige-100 text-beige-100 dark:text-brown-900 p-6 md:p-8 border-2 border-brown-900 dark:border-beige-100">
          <h1 class="font-ui text-2xl md:text-3xl font-bold mb-4">
            Tangut Character
          </h1>
          
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-left">
            <div>
              <dt class="font-ui text-xs font-semibold text-beige-300 dark:text-brown-600 mb-1 uppercase tracking-wide">Unicode</dt>
              <dd class="font-mono text-lg">{characterData.unicode_string}</dd>
            </div>
            
            <div>
              <dt class="font-ui text-xs font-semibold text-beige-300 dark:text-brown-600 mb-1 uppercase tracking-wide">Decimal</dt>
              <dd class="font-mono text-lg">{characterData.unicode.codePointAt(0)}</dd>
            </div>
            
            <div>
              <dt class="font-ui text-xs font-semibold text-beige-300 dark:text-brown-600 mb-1 uppercase tracking-wide">Block</dt>
              <dd class="font-ui text-sm font-medium">
                {characterData.unicode.codePointAt(0)! >= 0x18D00 ? 'Tangut Supplement' : 'Tangut'}
              </dd>
            </div>
            
            <div>
              <dt class="font-ui text-xs font-semibold text-beige-300 dark:text-brown-600 mb-1 uppercase tracking-wide">Category</dt>
              <dd class="font-ui text-sm font-medium">Ideograph</dd>
            </div>
          </div>
        </div>
        
        <div class="mt-8 space-y-6">
          <!-- Dictionary Info -->
          <div class="p-6 border-2 border-brown-900 dark:border-beige-100 bg-beige-100 dark:bg-brown-800">
            <h2 class="font-ui text-lg font-bold text-brown-900 dark:text-beige-100 mb-4">
              Dictionary Data
            </h2>
            
            <div class="grid grid-cols-2 gap-4 text-left">
              {characterData.xhzd_index && (
                <div>
                  <dt class="font-ui text-xs font-semibold text-brown-600 dark:text-beige-400 mb-1 uppercase tracking-wide">XHZD Index</dt>
                  <dd class="font-mono text-base text-brown-900 dark:text-beige-100">{characterData.xhzd_index}</dd>
                </div>
              )}
              
              {characterData.rhyme_class && (
                <div>
                  <dt class="font-ui text-xs font-semibold text-brown-600 dark:text-beige-400 mb-1 uppercase tracking-wide">Rhyme Class</dt>
                  <dd class="font-ui text-base text-brown-900 dark:text-beige-100">
                    <a href={`/rhyme/${characterData.rhyme_class}`} class="underline hover:no-underline focus-visible:outline-none">
                      {characterData.rhyme_class}
                    </a>
                  </dd>
                </div>
              )}

              {characterData.initial_class && (
                <div>
                  <dt class="font-ui text-xs font-semibold text-brown-600 dark:text-beige-400 mb-1 uppercase tracking-wide">Initial Class</dt>
                  <dd class="font-ui text-base text-brown-900 dark:text-beige-100">
                    <a href={`/initial/${characterData.initial_class}`} class="underline hover:no-underline focus-visible:outline-none">
                      {characterData.initial_class}
                    </a>
                  </dd>
                </div>
              )}
              
              {characterData.variant && (
                <div>
                  <dt class="font-ui text-xs font-semibold text-brown-600 dark:text-beige-400 mb-1 uppercase tracking-wide">Variant of</dt>
                  <dd class="text-base text-brown-900 dark:text-beige-100 font-tangut">
                    <a href={`/character/${getUnicodeString(characterData.variant)}`} class="underline hover:no-underline focus-visible:outline-none">
                      {characterData.variant}
                    </a>
                  </dd>
                </div>
              )}
            </div>
            {characterData.variant_warning && (
                <div class="mt-4 p-3 bg-yellow-100 dark:bg-yellow-900/50 border border-yellow-300 dark:border-yellow-700">
                  <p class="font-ui text-xs text-yellow-800 dark:text-yellow-200 font-medium">
                    Note: Variant status is uncertain.
                  </p>
                </div>
            )}
          </div>
          
          <!-- Relationships -->
          <RelatedCharacterSection title="VARIANTS" characters={characterData.variants} />
          <RelatedCharacterSection title="SYNONYMS" characters={characterData.synonyms} />
          <RelatedCharacterSection title="SIMILAR CHARACTERS" characters={similarCharacters} />

        </div>
      </div>
    </main>
  </div>
</Layout>
